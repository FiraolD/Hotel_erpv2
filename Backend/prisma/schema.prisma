generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model User {
 id        Int      @id @default(autoincrement())
 username  String   @unique
 password  String
 role      String
 createdAt DateTime @default(now())
}

model Room {
 id     Int    @id @default(autoincrement())
 number String
 type   String
 price  Float
 status String
}

model Reservation {
 id       Int @id @default(autoincrement())
 userId   Int
 roomId   Int
 checkIn  DateTime
 checkOut DateTime
}

model MenuItem {
 id       Int @id @default(autoincrement())
 name     String
 price    Float
 category String
}

model Order {
 id     Int @id @default(autoincrement())
 userId Int
 total  Float
 status String
}

model InventoryItem {
 id       Int @id @default(autoincrement())
 name     String
 quantity Float
 unit     String
}

model Transaction {
 id     Int @id @default(autoincrement())
 type   String
 amount Float
}

model Invoice {
 id        Int      @id @default(autoincrement())
 userId    Int
 total     Float
 status    String
 createdAt DateTime @default(now())
}

model Payment {
 id        Int      @id @default(autoincrement())
 invoiceId Int
 amount    Float
 method    String
 createdAt DateTime @default(now())
}

model Expense {
 id        Int      @id @default(autoincrement())
 title     String
 amount    Float
 category  String
 createdAt DateTime @default(now())
}

model HousekeepingTask {
 id        Int      @id @default(autoincrement())
 roomId    Int
 task      String
 status    String
 assignedTo Int?
 createdAt DateTime @default(now())
}

model EmailLog {
  id       Int      @id @default(autoincrement())
  to       String
  subject  String
  status   String
  createdAt DateTime @default(now())
}